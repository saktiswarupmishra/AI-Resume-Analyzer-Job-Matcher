{
  "name": "resume-analyzer-backend",
  "version": "1.0.0",
  "description": "Node.js API Gateway for AI Resume Analyzer",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev --name init",
    "prisma:seed": "node prisma/seed.js",
    "setup": "npx prisma generate && npx prisma migrate dev --name init && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "express-fileupload": "^1.5.1",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "prisma": "^5.20.0"
  }
}
